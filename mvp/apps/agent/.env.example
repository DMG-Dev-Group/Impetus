# Endereco do cerebro central. Em teste local, localhost.
# Em duas maquinas de verdade, o IP ou dominio da maquina que roda o brain.
WS_BRAIN_URL=ws://localhost:8080

# Nome desta maquina, como ele vai aparecer na resposta do WhatsApp.
# Precisa ser unico entre as maquinas do time.
