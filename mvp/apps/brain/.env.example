# Porta em que o servidor WebSocket escuta as conexoes dos agentes locais.
WS_PORT=8080

# Token de pareamento. Precisa ser IDENTICO ao PAIRING_SECRET de cada agente.
# Troque por um valor aleatorio e longo antes de rodar em qualquer maquina real.
PAIRING_SECRET=troque-isto-por-um-valor-aleatorio-longo

# Numeros autorizados a mandar comandos, separados por virgula.
# Formato internacional, so digitos, sem "+" e sem espacos.
# Mensagens de qualquer outro numero sao ignoradas em silencio.
WHATSAPP_ALLOWED_NUMBERS=5598900000000,5598911111111
