{
  "name": "@impetus/mvp",
  "version": "0.1.0",
  "private": true,
  "description": "MVP do Impetus — monorepo (cerebro central + agentes locais)",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:brain": "npm run dev --workspace @impetus/brain",
    "dev:agent": "npm run dev --workspace @impetus/agent",
    "smoke": "tsx scripts/smoke-transport.ts"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
